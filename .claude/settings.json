{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{try{const j=JSON.parse(d);const f=(j.tool_input||{}).file_path||'';if(!f)return;const fs=require('fs');const path=require('path');const b=path.basename(f);const dir=path.dirname(f);if(b==='CLAUDE.md')fs.copyFileSync(f,path.join(dir,'GEMINI.md'));else if(b==='GEMINI.md')fs.copyFileSync(f,path.join(dir,'CLAUDE.md'));}catch(e){}});\"",
            "statusMessage": "Syncing CLAUDE.md <-> GEMINI.md..."
          }
        ]
      }
    ]
  }
}